<Template>
  <WidgetGroup>
    <ObjectName>Deck</ObjectName>
    <Layout>vertical</Layout>
    <Children>
      <WidgetGroup>
        <ObjectName>DeckHeader</ObjectName>
        <Layout>horizontal</Layout>
        <Children>
<!--          <PushButton>-->
<!--            <ObjectName>DeckPlayButton</ObjectName>-->
<!--            <Size>30f,30f</Size>-->
<!--            <NumberStates>2</NumberStates>-->
<!--            <State>-->
<!--              <Number>0</Number>-->
<!--              <Text>&#9834;</Text>-->
<!--            </State>-->
<!--            <State>-->
<!--              <Number>1</Number>-->
<!--              <Text>&#9834;</Text>-->
<!--            </State>-->
<!--            <Connection>-->
<!--              <ButtonState>LeftButton</ButtonState>-->
<!--              <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>-->
<!--            </Connection>-->
<!--            <Connection>-->
<!--              <ConnectValueFromWidget>false</ConnectValueFromWidget>-->
<!--              <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>-->
<!--            </Connection>-->
<!--          </PushButton>-->
          <TrackProperty>
            <ObjectName>DeckTitle</ObjectName>
            <TooltipId>track_title</TooltipId>
            <SizePolicy>me,35f</SizePolicy>
            <Property>title</Property>
            <Channel><Variable name="channel"/></Channel>
            <Elide>right</Elide>
          </TrackProperty>
        </Children>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>DeckInfo</ObjectName>
        <Layout>horizontal</Layout>
        <Children>
          <WidgetGroup>
                <ObjectName>DeckControlsContainer</ObjectName>
                <Layout>horizontal</Layout>
                <Children>

                  <WidgetGroup>
                    <ObjectName>DeckControls</ObjectName>
                    <Layout>vertical</Layout>
                    <Children>

                      <WidgetGroup>
                        <ObjectName>DeckChannelTitleWrapper</ObjectName>
                        <Layout>horizontal</Layout>
                        <Size>80f, 40f</Size>
                        <Children>
                          <Label>
                            <ObjectName>DeckPlayingLeft</ObjectName>
                            <Text>((</Text>
                            <Style>
                              color: #d73535;
                            </Style>
                            <!-- To override basic style -->
                            <Connection>
                              <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>
                              <BindProperty>visible</BindProperty>
                            </Connection>
                          </Label>
                          <Label>
                            <ObjectName>DeckChannelTitle</ObjectName>
                            <Text>&#160;<Variable name="channel"/>&#160;</Text>
                          </Label>
                          <Label>
                            <ObjectName>DeckPlayingRight</ObjectName>
                            <Text>))</Text>
                            <Style>
                              color:#d73535
                            </Style>
                            <!-- To override basic style -->
                            <Connection>
                              <ConfigKey>[Channel<Variable name="channel"/>],play</ConfigKey>
                              <BindProperty>visible</BindProperty>
                            </Connection>
                          </Label>
                        </Children>
                      </WidgetGroup>

                      <Template src="skin:templates/toggle_button.xml">
                        <SetVariable name="TooltipId">vinylControl</SetVariable>
                        <SetVariable name="ObjectName">VinylControlButton</SetVariable>
                        <SetVariable name="Size">80f,40f</SetVariable>
                        <SetVariable name="State0Text">DVS</SetVariable>
                        <SetVariable name="State1Text">DVS</SetVariable>
                        <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],vinylcontrol_enabled</SetVariable>
                      </Template>
                    </Children>
                  </WidgetGroup>

                  <WidgetGroup>
                    <ObjectName>DeckControls2</ObjectName>
                    <Layout>vertical</Layout>
                    <Children>

                      <Template src="skin:templates/toggle_button.xml">
                        <SetVariable name="TooltipId">keylock</SetVariable>
                        <SetVariable name="ObjectName">KeylockButton</SetVariable>
                        <SetVariable name="Size">80f,40f</SetVariable>
                        <SetVariable name="State0Text">KEYLOCK</SetVariable>
                        <SetVariable name="State1Text">KEYLOCK</SetVariable>
                        <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],keylock</SetVariable>
                      </Template>

                      <Template src="skin:templates/toggle_button.xml">
                        <SetVariable name="TooltipId">quantize</SetVariable>
                        <SetVariable name="ObjectName">QuantizeButton</SetVariable>
                        <SetVariable name="Size">80f,40f</SetVariable>
                        <SetVariable name="State0Text">QUANTIZE</SetVariable>
                        <SetVariable name="State1Text">QUANTIZE</SetVariable>
                        <SetVariable name="LeftConnectionControl">[Channel<Variable name="channel"/>],quantize</SetVariable>
                      </Template>

                    </Children>
                  </WidgetGroup>
                </Children>
              </WidgetGroup>
          <WidgetGroup>
            <ObjectName>TrackTimeContainer</ObjectName>
            <Layout>vertical</Layout>
            <Size>0me,0me</Size>
            <Children>
              <Key>
                <ObjectName>WaveformInfo_Key</ObjectName>
                <TooltipId>visual_key</TooltipId>
                <Connection>
                  <ConfigKey>[Channel<Variable name="channel"/>],visual_key</ConfigKey>
                </Connection>
              </Key>
              <WidgetGroup>
                <ObjectName>DeckTrackTimeWrapper</ObjectName>
                <Layout>horizontal</Layout>
                <Size>0me,0me</Size>
                <Children>
                  <SizeAwareStack>
                    <Children>
                      <NumberPos>
                        <ObjectName>DeckTrackTimeMini</ObjectName>
                        <MaximumSize>150,-1</MaximumSize>
                        <TooltipId>track_time</TooltipId>
                        <NumberOfDigits>6</NumberOfDigits>
                        <Channel><Variable name="channel"/></Channel>
                        <Connection>
                          <ConfigKey>[Controls],ShowDurationRemaining</ConfigKey>
                          <Transform>
                            <IsEqual>2</IsEqual>
                          </Transform>
                          <BindProperty>highlight</BindProperty>
                        </Connection>
                      </NumberPos>
                      <NumberPos>
                        <ObjectName>DeckTrackTime</ObjectName>
                        <MinimumSize>150,-1</MinimumSize>
                        <TooltipId>track_time</TooltipId>
                        <NumberOfDigits>6</NumberOfDigits>
                        <Channel><Variable name="channel"/></Channel>
                        <Connection>
                          <ConfigKey>[Controls],ShowDurationRemaining</ConfigKey>
                          <Transform>
                            <IsEqual>2</IsEqual>
                          </Transform>
                          <BindProperty>highlight</BindProperty>
                        </Connection>
                      </NumberPos>
                    </Children>
                  </SizeAwareStack>
                </Children>
              </WidgetGroup>
            </Children>
          </WidgetGroup>
          <WidgetGroup>
            <ObjectName>TrackBPMContainer</ObjectName>
            <Layout>vertical</Layout>
            <Size>75max,0me</Size>
            <Children>
              <Label>
                <ObjectName>DeckTrackTimeTitle</ObjectName>
                <Text>BPM</Text>
                <Size>20me,25f</Size>
              </Label>
              <NumberBpm>
                <ObjectName>DeckBPM</ObjectName>
                <TooltipId>visual_bpm</TooltipId>
                <Channel><Variable name="channel"/></Channel>
                <Connection>
                  <ConfigKey>[Channel<Variable name="channel"/>],visual_bpm</ConfigKey>
                </Connection>
              </NumberBpm>

            </Children>
          </WidgetGroup>
        </Children>
        <Connection>
          <ConfigKey>[Tab],overview</ConfigKey>
          <!-- Only show info in overview -->
          <BindProperty>visible</BindProperty>
        </Connection>
      </WidgetGroup>
      <WidgetGroup>
        <ObjectName>DeckOverviewContainer</ObjectName>
        <Layout>vertical</Layout>
        <Size>0me,60f</Size>
        <Children>
          <Overview>
            <ObjectName>DeckOverview</ObjectName>
            <Size>0me,100f</Size>
            <Channel><Variable name="channel"/></Channel>
            <BgColor>#000</BgColor>
            <SignalColor>#222</SignalColor>
            <SignalLowColor>#007de1</SignalLowColor>
            <SignalMidColor>#007de1</SignalMidColor>
            <SignalHighColor>#007de1</SignalHighColor>
            <PlayedOverlayColor>#40ffffff</PlayedOverlayColor>
            <Mark>
              <Control>cue_point</Control>
              <Color>#eb870f</Color>
            </Mark>
	    <Mark>
          <Control>hotcue_1_position</Control>
          <Text>A</Text>
          <Color>#f44040</Color>
          <TextColor>#f44040</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_2_position</Control>
          <Text>B</Text>
          <Color>#0ddcf2</Color>
          <TextColor>#0ddcf2</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_3_position</Control>
          <Text>C</Text>
          <Color>#a5df13</Color>
          <TextColor>#a5df13</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_4_position</Control>
          <Text>D</Text>
          <Color>#9d4cfd</Color>
          <TextColor>#9d4cfd</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_5_position</Control>
          <Text>E</Text>
          <Color>#3fec2b</Color>
          <TextColor>#3fec2b</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_6_position</Control>
          <Text>F</Text>
          <Color>#e6681c</Color>
          <TextColor>#e6681c</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_7_position</Control>
          <Text>G</Text>
          <Color>#2749c8</Color>
          <TextColor>#2749c8</TextColor>
          <Align>top</Align>
        </Mark>
        <Mark>
          <Control>hotcue_8_position</Control>
          <Text>H</Text>
          <Color>#c7b205</Color>
          <TextColor>#c7b205</TextColor>
          <Align>top</Align>
        </Mark>
            <Mark>
              <Control>loop_start_position</Control>
              <Color>#6ee128</Color>
            </Mark>
            <Mark>
              <Control>loop_end_position</Control>
              <Color>#6ee128</Color>
            </Mark>
            <MarkRange>
              <StartControl>loop_start_position</StartControl>
              <EndControl>loop_end_position</EndControl>
              <EnabledControl>loop_enabled</EnabledControl>
              <Color>#6ee128</Color>
              <Opacity>0.8</Opacity>
              <DisabledColor>#acacac</DisabledColor>
              <DisabledOpacity>0.4</DisabledOpacity>
            </MarkRange>
            <Connection>
              <ConfigKey>[Channel<Variable name="channel"/>],playposition</ConfigKey>
            </Connection>
          </Overview>
        </Children>
      </WidgetGroup>
    </Children>
  </WidgetGroup>
</Template>
